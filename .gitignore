node_modules/
dist/
.DS_Store

# Local Netlify folder
.netlify

# raw Natural Earth source for cities.json (derived output lives in public/data)
places.geojson

# z6 land-polygon coastline grid (generated at build time, not committed — present on disk for Netlify deploy)
public/data/coast-z6/

# tiled Overture water layer (generated by `npm run build:watertiles`, not
# committed — same reasoning as coast-z6: present on disk for Netlify deploy,
# regenerate locally rather than bloating git with ~85 MB of derived tiles)
public/data/water-tiles/

# tiled Overture road layer (generated by `npm run build:roadtiles`, not
# committed — same reasoning as water-tiles above; this one is ~1 GB because
# the closest LOD keeps every road class including footway/steps per the
# project's no-simplification rule, see build-road-tiles.mjs)
public/data/road-tiles/
_staging/
